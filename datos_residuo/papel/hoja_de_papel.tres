[resource]
script = ExtResource("1_kbipf")
nombre = "Hoja De Papel"
imagen = SubResource("AtlasTexture_yvwxo")
descripcion = "Tipo De Residuo: Papel

Tiempo De Degradacion: 2 a 5 meses

Consejo De Disposicion: Asegúrate de que no tenga restos de comida o grasa; si está muy triturada, es mejor depositarla en una bolsa de papel para que no se disperse.

Impacto Ambiental: Su reciclaje evita la deforestación y reduce el consumo de energía y agua necesarios para fabricar papel nuevo desde cero."
categoria = "Papel"
metadata/_custom_type_script = "uid://k43gd28ijhr"
