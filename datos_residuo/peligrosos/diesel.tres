[resource]
script = ExtResource("2_ufs7j")
nombre = "Diesel"
imagen = SubResource("AtlasTexture_yp6n6")
descripcion = "Tipo De Residuo: Peligrosos

Tiempo De Degradacion: 1 a 10 años (dependiendo de las condiciones del suelo y la presencia de bacterias degradadoras)

Consejo De Disposicion: Nunca debe verterse en el drenaje ni directamente en la tierra; debe ser recolectado en recipientes herméticos y entregado a centros de manejo de residuos especiales o talleres que cuenten con sistemas de reciclaje de aceites y combustibles

Impacto Ambiental: Es altamente tóxico para la vida acuática y puede impermeabilizar el suelo, matando la microfauna y contaminando los mantos freáticos por periodos prolongados"
categoria = "Peligroso"
metadata/_custom_type_script = "uid://k43gd28ijhr"
