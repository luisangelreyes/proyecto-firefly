[resource]
script = ExtResource("1_s2w5d")
nombre = "Llaves"
imagen = SubResource("AtlasTexture_aphgt")
descripcion = "Tipo De Residuo: Metal

Tiempo De Degradacion: 30 a 100 años

Consejo De Disposicion: Si ya no funcionan, lo ideal es llevarlas a centros de reciclaje de metales o chatarra; también pueden agruparse en un contenedor metálico pequeño para asegurar que no se pierdan durante el proceso de recolección y facilitar su fundición

Impacto Ambiental: La mayoría de las llaves están hechas de latón, bronce o acero, materiales que son 100% reciclables. Al recuperarlas, se evita la extracción de nuevos minerales y se reduce significativamente la contaminación generada por la minería y el refinamiento de metales"
categoria = "Metal"
metadata/_custom_type_script = "uid://k43gd28ijhr"
